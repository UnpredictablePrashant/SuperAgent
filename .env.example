# =============================================================================
# Kendr Environment Configuration
# Copy this file to .env and fill in the values you need.
# Only OPENAI_API_KEY and KENDR_WORKING_DIR are required to get started.
# See docs/configuration.md for the full reference with defaults and examples.
# =============================================================================

# =============================================================================
# Core Runtime — required
# =============================================================================
KENDR_WORKING_DIR=""            # absolute path where run artifacts are written
KENDR_MODEL=""                  # short-form model override for all agents (falls back to OPENAI_MODEL)
KENDR_HOME="~/.kendr"           # root for local state (PID files, DB, plugin cache)
KENDR_PLUGIN_PATHS=""           # colon/comma-separated extra plugin directories
OUTPUT_DIR="output"             # default top-level output directory (relative to working dir)
RESEARCH_USER_AGENT="multi-agent-research-bot/1.0 (+https://localhost)"

# =============================================================================
# OpenAI — OPENAI_API_KEY is required; everything else is optional
# =============================================================================
OPENAI_API_KEY=""               # your OpenAI API key (required)
OPENAI_MODEL_GENERAL="gpt-4o-mini"   # model for orchestration, research, general agents
OPENAI_MODEL_CODING="gpt-4o-mini"    # model for coding-focused agents
OPENAI_MODEL="gpt-4o-mini"           # backward-compatible fallback model
OPENAI_VISION_MODEL="gpt-4o-mini"    # model for image analysis and OCR
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"  # model for vector embeddings

# =============================================================================
# Vector Backend — ChromaDB is the zero-config default (no variables needed)
# Set QDRANT_URL to opt in to Qdrant for persistent/shared deployments
# =============================================================================
QDRANT_URL=""                   # Qdrant endpoint; leave blank to use ChromaDB
QDRANT_API_KEY=""               # optional API key for authenticated Qdrant
QDRANT_COLLECTION="research_memory"  # default collection name

# =============================================================================
# Search — enables web/academic/patent search; optional but recommended
# =============================================================================
SERP_API_KEY=""                 # SerpAPI key — get it at serpapi.com

# =============================================================================
# Google Workspace (Gmail + Drive)
# Set GOOGLE_ACCESS_TOKEN for quick start, or the OAuth client fields for
# long-lived tokens. Run: kendr setup oauth google
# =============================================================================
GOOGLE_ACCESS_TOKEN=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://127.0.0.1:8787/oauth/google/callback"
GOOGLE_OAUTH_SCOPES="https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/drive.readonly"

# =============================================================================
# Microsoft Graph (Outlook + Teams + OneDrive)
# Set MICROSOFT_GRAPH_ACCESS_TOKEN for quick start, or the OAuth client fields.
# Run: kendr setup oauth microsoft
# =============================================================================
MICROSOFT_GRAPH_ACCESS_TOKEN=""
MICROSOFT_TENANT_ID="common"    # use your tenant ID or "common" for multi-tenant
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_REDIRECT_URI="http://127.0.0.1:8787/oauth/microsoft/callback"
MICROSOFT_OAUTH_SCOPES="offline_access User.Read Mail.Read Files.Read Team.ReadBasic.All"

# =============================================================================
# Slack
# Set SLACK_BOT_TOKEN for quick start, or the OAuth client fields.
# Run: kendr setup oauth slack
# =============================================================================
SLACK_BOT_TOKEN=""
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_REDIRECT_URI="http://127.0.0.1:8787/oauth/slack/callback"
SLACK_OAUTH_SCOPES="channels:read channels:history groups:read groups:history"

# =============================================================================
# Telegram
# Bot mode:          set TELEGRAM_BOT_TOKEN only
# User-session mode: set TELEGRAM_API_ID + TELEGRAM_API_HASH + TELEGRAM_SESSION_STRING
# See docs/integrations.md#telegram for how to generate a session string
# =============================================================================
TELEGRAM_BOT_TOKEN=""
TELEGRAM_API_ID=""
TELEGRAM_API_HASH=""
TELEGRAM_SESSION_STRING=""

# =============================================================================
# WhatsApp (Meta Cloud API)
# Get credentials at developers.facebook.com — WhatsApp > API Setup
# WHATSAPP_PHONE_NUMBER_ID is the phone number ID, not the phone number itself
# =============================================================================
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# =============================================================================
# Voice (ElevenLabs)
# =============================================================================
ELEVENLABS_API_KEY=""

# =============================================================================
# AWS
# Leave blank if using an instance profile, named profile, or the default chain
# =============================================================================
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""
AWS_DEFAULT_REGION="us-east-1"
AWS_PROFILE=""

# =============================================================================
# Gateway — controls the HTTP gateway server (kendr gateway start)
# The gateway is never auto-started; use kendr gateway start explicitly
# =============================================================================
SETUP_UI_HOST="127.0.0.1"
SETUP_UI_PORT="8787"
GATEWAY_HOST="127.0.0.1"
GATEWAY_PORT="8790"
DAEMON_POLL_INTERVAL="30"
DAEMON_HEARTBEAT_INTERVAL="300"

# =============================================================================
# Security and Privileged Mode — all disabled by default
# Enable only for authorized local command execution and security scan workflows
# =============================================================================
SECURITY_SCAN_PROFILE="standard"              # baseline | standard | deep | extensive
SECURITY_AUTO_INSTALL_TOOLS="true"            # auto-install nmap/zap/dependency-check
CVE_API_BASE_URL="https://services.nvd.nist.gov/rest/json/cves/2.0"
NVD_API_KEY=""                                # optional: raises NVD rate limits
KENDR_PRIVILEGED_MODE="false"                 # enable privileged policy controls
KENDR_REQUIRE_APPROVALS="true"                # require --privileged-approved flag
KENDR_READ_ONLY_MODE="false"                  # block all mutating commands
KENDR_ALLOW_ROOT="false"                      # allow sudo/root escalation
KENDR_ALLOW_DESTRUCTIVE="false"               # allow destructive operations
KENDR_ENABLE_BACKUPS="true"                   # snapshot before mutating actions
KENDR_ALLOWED_PATHS=""                        # comma-separated path roots allowed
KENDR_ALLOWED_DOMAINS=""                      # comma-separated domains allowed
KENDR_KILL_SWITCH_FILE="output/KENDR_STOP"    # halt if this file exists

# =============================================================================
# MCP Servers — only needed if running the MCP server cluster
# =============================================================================
MCP_RESEARCH_HOST="127.0.0.1"
MCP_RESEARCH_PORT="8081"
MCP_VECTOR_HOST="127.0.0.1"
MCP_VECTOR_PORT="8082"
MCP_SECURITY_HOST="127.0.0.1"
MCP_NMAP_PORT="8083"
MCP_ZAP_PORT="8084"
MCP_SCREENSHOT_PORT="8085"
MCP_HTTP_FUZZING_PORT="8086"
MCP_CVE_PORT="8087"
