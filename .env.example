# Core runtime
SUPERAGENT_WORKING_DIR="output/workspace"
SUPERAGENT_HOME="~/.superagent"
SUPERAGENT_PLUGIN_PATHS=""
OUTPUT_DIR="output"
RESEARCH_USER_AGENT="multi-agent-research-bot/1.0 (+https://localhost)"

# OpenAI
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL_GENERAL="gpt-4o-mini"
OPENAI_MODEL_CODING="gpt-5.3-codex"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_CODEX_MODEL="gpt-5.3-codex"
OPENAI_VISION_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Search and vector infrastructure
SERP_API_KEY=""
QDRANT_URL="http://127.0.0.1:6333"
QDRANT_API_KEY=""
QDRANT_COLLECTION="research_memory"

# Google Workspace
GOOGLE_ACCESS_TOKEN=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://127.0.0.1:8787/oauth/google/callback"
GOOGLE_OAUTH_SCOPES="https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/drive.readonly"

# Microsoft Graph
MICROSOFT_GRAPH_ACCESS_TOKEN=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"
MICROSOFT_REDIRECT_URI="http://127.0.0.1:8787/oauth/microsoft/callback"
MICROSOFT_OAUTH_SCOPES="offline_access User.Read Mail.Read Files.Read Team.ReadBasic.All"

# Slack
SLACK_BOT_TOKEN=""
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_REDIRECT_URI="http://127.0.0.1:8787/oauth/slack/callback"
SLACK_OAUTH_SCOPES="channels:read channels:history groups:read groups:history"

# Telegram
TELEGRAM_BOT_TOKEN=""
TELEGRAM_API_ID=""
TELEGRAM_API_HASH=""
TELEGRAM_SESSION_STRING=""

# WhatsApp
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# ElevenLabs
ELEVENLABS_API_KEY=""

# AWS
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""
AWS_DEFAULT_REGION="us-east-1"
AWS_PROFILE=""

# Setup and gateway surfaces
SETUP_UI_HOST="127.0.0.1"
SETUP_UI_PORT="8787"
GATEWAY_HOST="127.0.0.1"
GATEWAY_PORT="8790"
DAEMON_POLL_INTERVAL="30"
DAEMON_HEARTBEAT_INTERVAL="300"

# Security and privileged control
SECURITY_SCAN_PROFILE="standard"
SECURITY_AUTO_INSTALL_TOOLS="true"
CVE_API_BASE_URL="https://services.nvd.nist.gov/rest/json/cves/2.0"
NVD_API_KEY=""
SUPERAGENT_PRIVILEGED_MODE="false"
SUPERAGENT_REQUIRE_APPROVALS="true"
SUPERAGENT_READ_ONLY_MODE="false"
SUPERAGENT_ALLOW_ROOT="false"
SUPERAGENT_ALLOW_DESTRUCTIVE="false"
SUPERAGENT_ENABLE_BACKUPS="true"
SUPERAGENT_ALLOWED_PATHS=""
SUPERAGENT_ALLOWED_DOMAINS=""
SUPERAGENT_KILL_SWITCH_FILE="output/SUPERAGENT_STOP"

# MCP servers
MCP_RESEARCH_HOST="127.0.0.1"
MCP_RESEARCH_PORT="8081"
MCP_VECTOR_HOST="127.0.0.1"
MCP_VECTOR_PORT="8082"
MCP_SECURITY_HOST="127.0.0.1"
MCP_NMAP_PORT="8083"
MCP_ZAP_PORT="8084"
MCP_SCREENSHOT_PORT="8085"
MCP_HTTP_FUZZING_PORT="8086"
MCP_CVE_PORT="8087"
