{
  "name": "kendr-desktop",
  "version": "1.0.0",
  "description": "Kendr – AI Agent Orchestration Desktop",
  "main": "out/main/index.js",
  "author": "Kendr",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "ensure:icons": "node ./scripts/ensure-icons.mjs",
    "bundle:backend": "node ./scripts/build-backend-bundle.mjs",
    "build:release-assets": "npm run ensure:icons && npm run bundle:backend",
    "package": "npm run build:release-assets && npm run build && electron-builder",
    "package:win": "npm run build:release-assets && npm run build && electron-builder --win",
    "package:mac": "npm run build:release-assets && npm run build && electron-builder --mac",
    "package:linux": "npm run build:release-assets && npm run build && electron-builder --linux",
    "rebuild": "electron-rebuild -f -w node-pty",
    "build-icons": "node ../scripts/build-icons.mjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^0.452.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "vite": "^5.4.8"
  },
  "build": {
    "appId": "com.kendr.desktop",
    "productName": "Kendr",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": ".bundled-backend/kendr-backend",
        "to": "kendr-backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../",
        "to": "kendr-backend-source",
        "filter": [
          "gateway_server.py",
          "app.py",
          "kendr/**/*",
          "tasks/**/*",
          "mcp_servers/**/*",
          "plugin_templates/**/*",
          "project_templates/**/*",
          "pyproject.toml",
          "requirements.txt",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/*.pyo",
          "!**/.venv/**",
          "!**/electron-app/**",
          "!**/node_modules/**",
          "!**/tests/**",
          "!**/docs/**",
          "!**/output/**",
          "!**/logs/**",
          "!**/.git/**",
          "!**/dist/**",
          "!**/build/**",
          "!**/*.egg-info/**",
          "!**/attached_assets/**",
          "!**/openai_flowchart/**",
          "!**/.deps/**"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kendr"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.png",
      "category": "Development"
    }
  }
}
