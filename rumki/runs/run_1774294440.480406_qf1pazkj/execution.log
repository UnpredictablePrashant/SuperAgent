ups).Count\n$totalDupFiles = (@($dupGroups) | Measure-Object -Property Count -Sum).Sum\nif(-not $totalDupFiles){ $totalDupFiles = 0 }\n$totalReclaimable = (@($dupGroups) | Measure-Object -Property Reclaimable -Sum).Sum\nif(-not $totalReclaimable){ $totalReclaimable = 0 }\n$topGroups = @($dupGroups | Sort-Object Reclaimable -Descending | Select-Object -First 10)\n$largeGroups = @($dupGroups | Sort-Object Size -Descending | Select-Object -First 10)\nWrite-Output ('Duplicate File Analysis for ' + $root)\nWrite-Output ('Files scanned: ' + @($files).Count)\nWrite-Output ('Candidate size groups: ' + @($sizeGroups).Count)\nWrite-Output ('Duplicate groups: ' + $totalDupGroups)\nWrite-Output ('Files in duplicate groups: ' + $totalDupFiles)\nWrite-Output ('Estimated reclaimable space: ' + (Format-Bytes $totalReclaimable) + ' (' + $totalReclaimable + ' bytes)')\nWrite-Output ''\nWrite-Output 'Top duplicate groups by reclaimable space:'\nif($topGroups.Count -eq 0){ Write-Output '  None found.' } else {\n  $i=1\n  foreach($g in $topGroups){\n    Write-Output ('  [' + $i + '] copies=' + $g.Count + ' size=' + (Format-Bytes $g.Size) + ' reclaimable=' + (Format-Bytes $g.Reclaimable))\n    Write-Output ('      hash=' + $g.Hash)\n    foreach($p in ($g.Paths | Select-Object -First 5)){ Write-Output ('      ' + $p) }\n    if(@($g.Paths).Count -gt 5){ Write-Output ('      ... +' + (@($g.Paths).Count-5) + ' more') }\n    $i++\n  }\n}\nWrite-Output ''\nWrite-Output 'Notable large duplicate groups:'\nif($largeGroups.Count -eq 0){ Write-Output '  None found.' } else {\n  $i=1\n  foreach($g in $largeGroups){\n    Write-Output ('  [' + $i + '] copies=' + $g.Count + ' size=' + (Format-Bytes $g.Size) + ' reclaimable=' + (Format-Bytes $g.Reclaimable))\n    Write-Output ('      hash=' + $g.Hash)\n    foreach($p in ($g.Paths | Select-Object -First 3)){ Write-Output ('      ' + $p) }\n    if(@($g.Paths).Count -gt 3){ Write-Output ('      ... +' + (@($g.Paths).Count-3) + ' more') }\n    $i++\n  }\n}\